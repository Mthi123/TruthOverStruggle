@{
    ViewData["Title"] = "Journal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col-md-6">
            <h3>New Journal Entry</h3>
            <form>
                <div class="mb-3">
                    <label for="journalTitle" class="form-label">Title</label>
                    <input type="text" id="journalTitle" name="Title" class="form-control" placeholder="Enter Title" />
                </div>

                <div class="mb-3">
                    <label for="Date" class="form-label">Date</label>

                    <input type="date" id="Date" name="Date"
                           class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>

                <div class="mb-3">
                    <label for="journalMood" class="form-label">Mood</label>
                    <input type="text" id="journalMood" name="Mood" class="form-control" placeholder="Sad" />
                </div>

                <div class="mb-3">
                    <label for="journalContent" class="form-label">Content</label>
                    <!-- textarea is NOT self-closing -->
                    <textarea id="journalContent" name="Content" class="form-control" placeholder="Go on, let your feelings out."></textarea>
                </div>

                <button type="submit" class="btn btn-primary" id="submitBtn">Submit</button>
            </form>
        </div>

        <div class="col-md-6">
            <h3>My Journal Entries</h3>

            <input type="date" id="journalDate" class="form-control mb-2" />
            <button class="btn btn-secondary mb-3" onclick="loadJournalsByDate()">Load Journals</button>

            <ul id="journalList" class="list-group"></ul>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadJournalsByDate() {
            const dateInput = document.getElementById('journalDate').value;
            if (!dateInput) {
                alert("Please select a date!");
                return;
            }

            // If your API expects yyyy-MM-dd, this matches the <input type="date"> value.
            const response = await fetch(`/api/Journal/${dateInput}`);
            if (!response.ok) {
                alert("Couldn't fetch journals!");
                return;
            }

            const journals = await response.json();
            const list = document.getElementById('journalList');
            list.innerHTML = '';

            journals.forEach(j => {
                const li = document.createElement('li');
                li.className = 'list-group-item';
                const dateStr = new Date(j.date).toLocaleDateString();
                li.textContent = `${dateStr} - ${j.title}`;
                list.appendChild(li);
            });
        }
    </script>
}